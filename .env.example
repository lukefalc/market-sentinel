# Local environment settings for market-sentinel.
# Copy this file to .env and update the values when needed.

MARKET_SENTINEL_ENV=development
MARKET_SENTINEL_LOG_LEVEL=INFO
MARKET_SENTINEL_DATABASE_PATH=data/market_sentinel.duckdb

# Data downloading is not implemented yet.
# Future API keys can be added here, but never commit real secrets.
MARKET_DATA_API_KEY=

# Email alerts are disabled by default.
# Use an app password or provider-specific SMTP password, never your main login.
MARKET_SENTINEL_EMAIL_ENABLED=false
MARKET_SENTINEL_SMTP_HOST=smtp.example.com
MARKET_SENTINEL_SMTP_PORT=587
MARKET_SENTINEL_SMTP_USERNAME=your_email@example.com
MARKET_SENTINEL_SMTP_PASSWORD=your_app_password_here
MARKET_SENTINEL_EMAIL_FROM=your_email@example.com
MARKET_SENTINEL_EMAIL_TO=your_email@example.com
